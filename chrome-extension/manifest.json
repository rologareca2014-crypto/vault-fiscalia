{
  "manifest_version": 3,
  "name": "VaultFiscalia Extension",
  "version": "1.1",
  "description": "Extensión oficial para guardar y autocompletar contraseñas directamente en VaultFiscalia.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VaultFiscalia Bóveda"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
